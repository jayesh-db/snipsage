# ============================================================
# SnipSage — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # "production" on Vercel (set automatically)

# ── MongoDB ──────────────────────────────────────────────────
# Local dev:    mongodb://localhost:27017/snipsage
# Atlas (prod): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/snipsage
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/snipsage?appName=Cluster0

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# ── Google AI (Gemini + Embeddings) ───────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-api-key-here

# ── Vector Store ──────────────────────────────────────────────
# "memory"  → in-memory store, rebuilt from MongoDB on each cold start
#             Good for local dev and single-user personal use.
# "atlas"   → MongoDB Atlas Vector Search (stateless, ideal for serverless/Vercel)
#             Requires: Atlas M0+ cluster + vector_index created on Content collection
VECTOR_STORE_TYPE=atlas

# ── MongoDB Atlas Vector Search ───────────────────────────────
# Only required when VECTOR_STORE_TYPE=atlas
# Must match the index name you created in Atlas Search UI
ATLAS_VECTOR_SEARCH_INDEX_NAME=vector_index

# ── CORS (optional) ───────────────────────────────────────────
# Set this to your custom domain if you have one (e.g., https://snipsage.example.com)
# If not set, Vercel's assigned *.vercel.app domain is permitted automatically.
# FRONTEND_URL=https://your-custom-domain.com
