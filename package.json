{
  "name": "snipsage",
  "version": "1.0.0",
  "description": "AI-Powered Personal Knowledge Assistant — capture web content, build a private knowledge base, and chat with AI grounded in your data.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx nodemon --exec npx ts-node src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": ["ai", "rag", "knowledge-base", "chrome-extension", "langchain", "gemini"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
